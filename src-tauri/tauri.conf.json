{
  "productName": "Biological Compiler",
  "identifier": "com.bio-pro.app",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Biological Compiler",
        "width": 1600,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "backend-server-dist/": "backend-server/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
